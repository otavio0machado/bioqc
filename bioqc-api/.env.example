# Reference of the environment variables expected by bioqc-api.
# Local dev uses the `local` Spring profile (H2 in-memory, no SMTP, no flyway).
# For Supabase + Railway production, set these in Railway's variables panel.

# === Spring profile ===
SPRING_PROFILES_ACTIVE=prod

# === Database (Supabase Postgres) ===
# Settings -> Database -> JDBC connection string
SUPABASE_DB_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=change-me

# === JWT ===
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-to-a-64-char-or-longer-base64-secret

# === Flyway ===
FLYWAY_BASELINE_ON_MIGRATE=true

# === Auth cookies (cross-origin Vercel <-> Railway) ===
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=None

# === CORS ===
# Exact origin of your Vercel deployment (no trailing slash)
CORS_ALLOWED_ORIGINS=https://bioqc-demo.vercel.app

# === Demo seed (creates admin + analyst + lab settings on boot) ===
# Only set to true on the demo deployment, never on real lab data.
BIOQC_DEMO_SEED=true

# === Optional: AI commentary (Gemini) ===
# Leave blank to disable AI features.
GEMINI_API_KEY=

# === Optional: SMTP for password reset ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
PASSWORD_RESET_FROM_EMAIL=no-reply@demo.bioqc.dev

# === Server port (Railway sets this automatically) ===
PORT=8080
