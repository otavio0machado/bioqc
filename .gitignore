# --- Java / Maven ---
target/
*.class
*.war
*.ear
hs_err_pid*
# .mvn/ is needed by Maven Wrapper (./mvnw) — keep it tracked.
# Only ignore the wrapper jar (some setups have it, some don't).
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# --- Node / Vite ---
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local

# --- IDE ---
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
.apt_generated/
.springBeans

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Env / secrets ---
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
secrets/
credentials.json

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# --- Coverage / reports ---
coverage/
.nyc_output/
*.lcov
surefire-reports/
failsafe-reports/

